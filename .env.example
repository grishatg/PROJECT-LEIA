# PROJECT-LEIA secrets — copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# ── The brain (required) ───────────────────────────────────────────────
# Pay-as-you-go Anthropic API key from https://console.anthropic.com
# This is SEPARATE from your Claude Max chat subscription.
# Tip: set a low monthly spend cap in the Anthropic console as a guardrail.
ANTHROPIC_API_KEY=

# ── Enrichment (Phase 1) ───────────────────────────────────────────────
# Lusha (email + firmographic lookup): https://www.lusha.com  (API key in dashboard)
LUSHA_API_KEY=

# ── Email sending (Phase 1) ────────────────────────────────────────────
# Instantly cold-email API key: https://instantly.ai
INSTANTLY_API_KEY=
# The Instantly campaign approved leads are added to. Your campaign template
# should reference {{leia_subject}} and {{leia_body}} custom variables.
INSTANTLY_CAMPAIGN_ID=

# ── LinkedIn (Phase 2 — leave blank for now) ───────────────────────────
APIFY_TOKEN=
UNIPILE_API_KEY=
UNIPILE_DSN=

# ── UK discovery + booking (Phase 2) ───────────────────────────────────
# Companies House (free): https://developer.company-information.service.gov.uk
# Used by the `companies_house` discovery source (SIC/region → officers).
COMPANIES_HOUSE_API_KEY=
# Your public Outlook / Microsoft Bookings link. Shared in conversation replies
# when a meeting is proposed (no calendar API — IT restriction).
BOOKING_URL=

# ── App settings (optional overrides) ──────────────────────────────────
# Defaults to a local SQLite file at data/leia.db. Swap to a Postgres URL
# when you productize, e.g. postgresql+psycopg://user:pass@host:5432/leia
DATABASE_URL=

# ── Hosted login + database (Supabase) — only needed when deploying ─────
# Leave blank for local use (the web login is skipped on localhost).
# See DEPLOY.md for where to find these in the Supabase dashboard.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
