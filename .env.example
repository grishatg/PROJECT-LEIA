# ─────────────────────────────────────────────────────────────
# PROJECT LEIA — AI Lead Gen
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────

# --- Core app ---
NODE_ENV=development
APP_PORT=3000
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- LLM / AI (Anthropic Claude) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Default model used for lead reasoning / drafting
ANTHROPIC_MODEL=claude-opus-4-8

# --- Lead data / enrichment (Lusha) ---
# https://www.lusha.com/  (prospecting + contact/company enrichment)
LUSHA_API_KEY=

# --- Database ---
# e.g. postgres://user:pass@localhost:5432/leia
DATABASE_URL=

# --- Email / outreach ---
# If using Gmail / Google Workspace OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Or generic SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- CRM / workspace integrations (optional) ---
NOTION_API_KEY=

# --- Security ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=
JWT_SECRET=
